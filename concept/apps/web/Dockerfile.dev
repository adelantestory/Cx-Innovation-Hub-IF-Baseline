# =============================================================================
# Taskify Frontend - Development Dockerfile
# =============================================================================
# This Dockerfile is used ONLY for local development via docker-compose.
# It runs the Vite dev server with hot module replacement (HMR) for instant
# updates in the browser when source files change.
#
# Key differences from production Dockerfile:
#   - Runs Vite dev server (not Nginx serving static build)
#   - HMR enabled for instant browser updates
#   - Source code is bind-mounted from host (not copied into image)
#   - No multi-stage build
#   - No npm run build step
# =============================================================================

FROM node:20-alpine

WORKDIR /app

# Copy package files and install dependencies
# These are copied (not mounted) so npm install runs inside the container.
# Source code and config files are bind-mounted in docker-compose.yml.
COPY package*.json ./
RUN npm install

# Source code and config files are bind-mounted from docker-compose.yml.
# No COPY of source code here -- changes on host are reflected immediately.

EXPOSE 5173

# Start Vite dev server
# --host 0.0.0.0 is required so the container accepts connections from
# outside (the Docker bridge network / host machine).
CMD ["npx", "vite", "--host", "0.0.0.0", "--port", "5173"]
