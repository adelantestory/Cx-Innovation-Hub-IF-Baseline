# =============================================================================
# Local Development Environment Variables
# =============================================================================
# Copy this file to .env.docker and set your own values before running
# docker compose up. The .env.docker file is gitignored and will not be
# committed to source control.
#
#   cp .env.docker.example .env.docker
#
# =============================================================================

# PostgreSQL credentials — used by the db service and the api service
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_min16chars_AlphaNumericSpecial!
POSTGRES_DB=taskify

# API service — matches POSTGRES_* above
PGUSER=postgres
PGPASSWORD=CHANGE_ME_min16chars_AlphaNumericSpecial!
PGDATABASE=taskify
PGPORT=5432
PGSSLMODE=disable
