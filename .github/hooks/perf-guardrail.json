{
  "hooks": {
    "PreToolUse": [
      {
        "type": "command",
        "command": ".github/hooks/scripts/perf-guardrail.sh pre-tool",
        "windows": "powershell -ExecutionPolicy Bypass -File .github\\hooks\\scripts\\perf-guardrail.ps1 pre-tool",
        "timeout": 30
      }
    ],
    "PostToolUse": [
      {
        "type": "command",
        "command": ".github/hooks/scripts/perf-guardrail.sh post-tool",
        "windows": "powershell -ExecutionPolicy Bypass -File .github\\hooks\\scripts\\perf-guardrail.ps1 post-tool",
        "timeout": 30
      }
    ]
  }
}
